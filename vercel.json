{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "maxLambdaSize": "15mb"
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(build|css|js|image|images)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "ADI Chad",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://adi-chad.vercel.app",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "info",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "SESSION_LIFETIME": "120",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "local",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "/tmp/database.sqlite",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views"
    }
}