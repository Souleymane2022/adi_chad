{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "maxLambdaSize": "15mb"
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|build)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "ADI Chad",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://adi-chad-git-main-souleymanemahamatsaleh2000-8176s-projects.vercel.app",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "SESSION_LIFETIME": "120",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "local",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "/tmp/database.sqlite"
    }
}